# Copy this file to .env and fill in real values
# Never commit .env — it contains live secrets

# Required: Google Gemini API key for vision analysis (free tier available)
# Get yours at: https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key-here

# Required for Streamlit in production: URL of the deployed FastAPI backend
# Leave unset for local development (defaults to http://127.0.0.1:8000/api/v1)
# API_BASE_URL=https://myvastu-api.onrender.com/api/v1
